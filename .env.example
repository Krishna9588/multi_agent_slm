# =============================================================================
# Autonomous Swarm — Environment Configuration
# =============================================================================
# This file stores all API keys, credentials, and service tokens.
# NEVER commit this file to Git. It is listed in .gitignore.
#
# For keys that support multiple instances (e.g., Gemini rate-limit rotation),
# add numbered suffixes: GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc.
# The system auto-discovers all keys matching the prefix.
# =============================================================================


# ── Gemini API Keys (Cloud LLM Fallback) ──────────────────────────────────────
# Primary key (used first)
GEMINI_API_KEY=Gemini_key

# Additional keys for rate-limit rotation (auto-discovered by prefix match)
GEMINI_API_KEY_1=your_second_gemini_key_here
GEMINI_API_KEY_2=your_third_gemini_key_here
# GEMINI_API_KEY_3=add_more_as_needed


# ── Email Agent (IMAP / SMTP) ─────────────────────────────────────────────────
# Required for: email_agent (read_inbox, send_email)
# For Gmail: Use an App Password, NOT your real password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Optional overrides (defaults to Gmail servers if not set)
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587


# ── External Scraping Services ────────────────────────────────────────────────
# Required for: external_service_agent (Apify actors, BrightData datasets)

# Apify — https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_key
# APIFY_TOKEN_1=your_second_apify_token_here

# Bright Data — https://brightdata.com/cp/setting
BRIGHTDATA_TOKEN=7758e95b-BrightData_token
# BRIGHTDATA_TOKEN_1=your_second_brightdata_token_here


# ── GitHub Agent ───────────────────────────────────────────────────────────────
# Required for: github_agent (cloning private repos, pushing commits)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here


# ── Social Media Agent ─────────────────────────────────────────────────────────
# Required for: social_media_agent (reading mentions, posting)
# Twitter/X Bearer Token — https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ── E2B Cloud Sandbox (Fallback Isolation) ────────────────────────────────
E2B_API_KEY=e2b_api_key_here

